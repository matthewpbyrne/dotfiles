# shellcheck shell=sh
# Shared login-shell environment

# Shared static environment for login shells
# shellcheck source=/dev/null
[ -f "$HOME/.shell/env_static.sh" ] && . "$HOME/.shell/env_static.sh"

# Secrets
# shellcheck source=/dev/null
[ -f "$HOME/.shell/secrets.sh" ] && . "$HOME/.shell/secrets.sh"

# Optional environment manager
# shellcheck source=/dev/null
[ -s "$HOME/.config/envman/load.sh" ] && . "$HOME/.config/envman/load.sh"

: "${PATH:=}"

path_prepend() {
  [ -n "$1" ] || return 0

  old_ifs=$IFS
  IFS=:
  new_path=

  for dir in $PATH; do
    [ -z "$dir" ] && continue
    [ "$dir" = "$1" ] && continue
    if [ -z "$new_path" ]; then
      new_path=$dir
    else
      new_path=$new_path:$dir
    fi
  done

  IFS=$old_ifs
  PATH=$1${new_path:+:$new_path}
}

path_prepend_if_dir() {
  [ -d "$1" ] || return 0
  path_prepend "$1"
}

# Add a dynamically discovered tool directory to PATH.
# Assumes path_prepend() has already been defined by .profile.
add_tool_path() {
  [ -n "$1" ] || return 0
  path_prepend "$1"
}

# system paths (lowest priority)
path_prepend_if_dir "/snap/bin"
path_prepend_if_dir "/bin"
path_prepend_if_dir "/usr/bin"
path_prepend_if_dir "/usr/local/bin"
path_prepend_if_dir "/home/linuxbrew/.linuxbrew/bin"

# language managers
path_prepend "$MISE_DATA_DIR/shims"

# package managers
path_prepend "${PNPM_HOME:-$HOME/.local/share/pnpm}"

# language tools
[ -n "${GOBIN:-}" ] && path_prepend "$GOBIN"
path_prepend "$HOME/.cargo/bin"
path_prepend "$HOME/.cabal/bin"
path_prepend "$HOME/.ghcup/bin"
path_prepend "$HOME/.luarocks/bin"

# user tools (highest priority)
path_prepend "$HOME/.local/bin"

export PATH

# Shared dynamic/tool-dependent environment
# shellcheck source=/dev/null
[ -f "$HOME/.shell/env_dynamic.sh" ] && . "$HOME/.shell/env_dynamic.sh"
