# Managed by chezmoi

# Shared static environment + secrets
[ -f "$HOME/.profile" ] && . "$HOME/.profile"

# zsh PATH cleanup (dedupe PATH entries)
[ -f "$HOME/.config/zsh/zsh_path_dedupe.zsh" ] && . "$HOME/.config/zsh/zsh_path_dedupe.zsh"

# Emacs-style command-line editing
bindkey -e

# NOTE: Zsh plugins read shell variables directly.
# Theming, including autosuggestions
[ -f "$HOME/.config/zsh/themes/tokyo-night-storm.zsh" ] && . "$HOME/.config/zsh/themes/tokyo-night-storm.zsh"
ZSH_AUTOSUGGEST_STRATEGY=(history completion)

# Shared shell files
[ -f "$HOME/.shell/aliases.sh" ] && . "$HOME/.shell/aliases.sh"
[ -f "$HOME/.shell/functions.sh" ] && . "$HOME/.shell/functions.sh"
[ -f "$HOME/.shell/functions_workspaces.sh" ] && . "$HOME/.shell/functions_workspaces.sh"

# Zsh-specific shell files
[ -f "$ZDOTDIR/aliases.zsh" ] && . "$ZDOTDIR/aliases.zsh"
[ -f "$ZDOTDIR/functions.zsh" ] && . "$ZDOTDIR/functions.zsh"

# Optional ghcup
[ -f "$HOME/.ghcup/env" ] && . "$HOME/.ghcup/env"

# Antidote / Oh My Zsh-compatible plugins
ANTIDOTE_HOME="${XDG_DATA_HOME:-$HOME/.local/share}/antidote"
ZSH_PLUGINS_FILE="${ZDOTDIR:-$HOME}/.zsh_plugins.txt"
ZSH_PLUGINS_BUNDLE="${ZDOTDIR:-$HOME}/.zsh_plugins.zsh"
ZSH_PLUGINS_LATE_FILE="${ZDOTDIR:-$HOME}/.zsh_plugins_late.txt"
ZSH_PLUGINS_LATE_BUNDLE="${ZDOTDIR:-$HOME}/.zsh_plugins_late.zsh"

build_antidote_bundle() {
  local plugins_file="$1"
  local bundle_file="$2"
  local tmp_bundle

  [ -f "$ANTIDOTE_HOME/antidote.zsh" ] || return 0
  [ -f "$plugins_file" ] || return 0

  if [ ! -f "$bundle_file" ] || [ "$plugins_file" -nt "$bundle_file" ]; then
    (
      source "$ANTIDOTE_HOME/antidote.zsh" || exit 1
      tmp_bundle="$(mktemp "${bundle_file}.XXXXXX")" || exit 1
      trap 'rm -f "$tmp_bundle"' EXIT

      if antidote bundle <"$plugins_file" >"$tmp_bundle"; then
        mv "$tmp_bundle" "$bundle_file"
        trap - EXIT
      else
        exit 1
      fi
    )
  fi
}

build_antidote_bundle "$ZSH_PLUGINS_FILE" "$ZSH_PLUGINS_BUNDLE"
[ -f "$ZSH_PLUGINS_BUNDLE" ] && source "$ZSH_PLUGINS_BUNDLE"

build_antidote_bundle "$ZSH_PLUGINS_LATE_FILE" "$ZSH_PLUGINS_LATE_BUNDLE"

append_fzf_preview_opt() {
  local opts_var="$1"
  local preview_cmd="$2"
  local current_opts
  local preview_quoted
  local new_value

  [ -n "$preview_cmd" ] || return 0
  # Use zsh-native quoting so preview commands containing quotes remain a
  # single shell word when stored in FZF_*_OPTS.
  preview_quoted="${(qq)preview_cmd}"
  current_opts="${(P)opts_var:-}"
  case " ${current_opts:-} " in
    *" --preview "*|*" --preview="*) return 0 ;;
  esac
  new_value="${current_opts:+$current_opts }--preview=${preview_quoted}"
  typeset -gx "$opts_var=$new_value"
}

# Completion
autoload -Uz compinit
zstyle ':completion:*' menu select

if [ -f "${ZDOTDIR:-$HOME}/.zcompdump" ]; then
	compinit -C
else
	compinit
fi

# direnv
if (( $+commands[direnv] )); then
  eval "$(direnv hook zsh)"
fi

# zoxide (directory jumping without overriding cd)
if (( $+commands[zoxide] )); then
  eval "$(zoxide init zsh --cmd z)"
fi

# fzf integration
if command -v fzf >/dev/null 2>&1; then
  if typeset -f _fzf_preview_cmd >/dev/null 2>&1; then
    file_preview_cmd="$(_fzf_preview_cmd)"
  else
    file_preview_cmd="sh -c 'sed -n \"1,200p\" < \"\$1\" 2>/dev/null || head -n 200 < \"\$1\" 2>/dev/null' sh {}"
  fi

  if typeset -f _fzf_dir_preview_cmd >/dev/null 2>&1; then
    dir_preview_cmd="$(_fzf_dir_preview_cmd)"
  else
    if command -v eza >/dev/null 2>&1; then
      dir_preview_cmd="eza --long --all -- {}"
    else
      # Keep option-safe handling for dash-prefixed paths while remaining
      # compatible with BSD/macOS ls variants that may reject `--`.
      dir_preview_cmd="sh -c 'ls -la -- \"$1\" 2>/dev/null || ls -la \"$1\" 2>/dev/null' sh {}"
    fi
  fi

  append_fzf_preview_opt FZF_CTRL_T_OPTS "$file_preview_cmd"
  append_fzf_preview_opt FZF_ALT_C_OPTS "$dir_preview_cmd"

  if fzf_zsh="$(fzf --zsh 2>/dev/null)"; then
    eval "$fzf_zsh"
    unset fzf_zsh
  else
    fzf_shell_dir=""
    for dir in /usr/share/fzf /opt/homebrew/opt/fzf/shell; do
      if [[ -f "$dir/key-bindings.zsh" ]] || [[ -f "$dir/completion.zsh" ]]; then
        fzf_shell_dir="$dir"
        break
      fi
    done
    if [[ -n "$fzf_shell_dir" ]]; then
      [[ -f "$fzf_shell_dir/key-bindings.zsh" ]] && source "$fzf_shell_dir/key-bindings.zsh"
      [[ -f "$fzf_shell_dir/completion.zsh" ]] && source "$fzf_shell_dir/completion.zsh"
    fi
    unset fzf_shell_dir
  fi

  unset file_preview_cmd
  unset dir_preview_cmd
fi

# prompt
if command -v starship >/dev/null 2>&1; then
	export STARSHIP_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/starship.toml"
	eval "$(starship init zsh)"
else
	PROMPT='%n@%m:%~ %# '
fi

# Reassert preferred bindings after plugin/framework init
bindkey -e
bindkey '^A' beginning-of-line
bindkey '^E' end-of-line
bindkey '^P' up-line-or-history
bindkey '^N' down-line-or-history

# Edit current command in $EDITOR
autoload -Uz edit-command-line
zle -N edit-command-line
bindkey '^X^E' edit-command-line

# Load late plugins (syntax highlighting etc.)
[ -f "$ZSH_PLUGINS_LATE_BUNDLE" ] && source "$ZSH_PLUGINS_LATE_BUNDLE"
