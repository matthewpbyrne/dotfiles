# Managed by chezmoi

# Shared static environment + secrets
[ -f "$HOME/.profile" ] && . "$HOME/.profile"

# Emacs-style command-line editing
bindkey -e

# Shared shell files
[ -f "$HOME/.shell/aliases.sh" ] && . "$HOME/.shell/aliases.sh"
[ -f "$HOME/.shell/functions.sh" ] && . "$HOME/.shell/functions.sh"
[ -f "$HOME/.shell/functions_workspaces.sh" ] && . "$HOME/.shell/functions_workspaces.sh"

# Zsh-specific shell files
[ -f "$ZDOTDIR/aliases.zsh" ] && . "$ZDOTDIR/aliases.zsh"
[ -f "$ZDOTDIR/functions.zsh" ] && . "$ZDOTDIR/functions.zsh"

# Optional ghcup
[ -f "$HOME/.ghcup/env" ] && . "$HOME/.ghcup/env"

# Dynamic/tool-dependent environment
[ -f "$HOME/.shell/env_dynamic.sh" ] && . "$HOME/.shell/env_dynamic.sh"

# Completion
autoload -Uz compinit
zstyle ':completion:*' menu select

if [ -f "${ZDOTDIR:-$HOME}/.zcompdump" ]; then
  compinit -C
else
  compinit
fi

# Antigen / Oh My Zsh
if [ -f "$HOME/.local/lib/antigen.zsh" ]; then
  source "$HOME/.local/lib/antigen.zsh"

  antigen use oh-my-zsh

  antigen bundles <<'EOBUNDLES'
command-not-found
docker
fasd
fzf
git
gitignore
lein
pip
zsh-users/zsh-completions
zsh-users/zsh-syntax-highlighting
EOBUNDLES

  antigen theme amuse
  antigen apply
fi

# PATH hygiene
typeset -U path
path=(${path:#$HOME/.antigen/bundles/*})
path=(${path:#""})
export PATH

# direnv
(( $+commands[direnv] )) && eval "$(direnv hook zsh)"

# prompt
if command -v starship >/dev/null 2>&1; then
  export STARSHIP_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/starship.toml"
  eval "$(starship init zsh)"
else
  PROMPT='%n@%m:%~ %# '
fi

# Reassert preferred bindings after plugin/framework init
bindkey -e
bindkey '^A' beginning-of-line
bindkey '^E' end-of-line
bindkey '^P' up-line-or-history
bindkey '^N' down-line-or-history

# Edit current command in $EDITOR
autoload -Uz edit-command-line
zle -N edit-command-line
bindkey '^X^E' edit-command-line
