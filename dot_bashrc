# shellcheck shell=bash
# Managed by chezmoi

# Exit if non-interactive shell
case $- in
*i*) ;;
*) return ;;
esac

# Shared static environment + secrets + envman
# shellcheck source=/dev/null
[ -f "$HOME/.profile" ] && . "$HOME/.profile"

# Ensure Homebrew is on PATH if available
if [ -x /home/linuxbrew/.linuxbrew/bin/brew ]; then
	export PATH="/home/linuxbrew/.linuxbrew/bin:$PATH"
fi

# Shared shell files
# shellcheck source=/dev/null
[ -f "$HOME/.shell/aliases.sh" ] && . "$HOME/.shell/aliases.sh"
# shellcheck source=/dev/null
[ -f "$HOME/.shell/functions.sh" ] && . "$HOME/.shell/functions.sh"
# shellcheck source=/dev/null
[ -f "$HOME/.shell/functions_scratch.sh" ] && . "$HOME/.shell/functions_scratch.sh"

# asdf via Homebrew
if command -v brew >/dev/null 2>&1; then
	ASDF_PREFIX="$(brew --prefix asdf 2>/dev/null)"
	if [ -n "$ASDF_PREFIX" ] && [ -f "$ASDF_PREFIX/libexec/asdf.sh" ]; then
		# shellcheck source=/dev/null
		. "$ASDF_PREFIX/libexec/asdf.sh"
	fi
fi

# Dynamic environment (after tools exist)
# shellcheck source=/dev/null
[ -f "$HOME/.shell/env_dynamic.sh" ] && . "$HOME/.shell/env_dynamic.sh"

# direnv
command -v direnv >/dev/null 2>&1 && eval "$(direnv hook bash)"

# History tweaks
HISTCONTROL=ignoreboth
HISTSIZE=5000
HISTFILESIZE=10000
shopt -s histappend

# Minimal prompt
PS1='\u@\h:\w\$ '
